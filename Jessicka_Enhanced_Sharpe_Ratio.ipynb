    "for th in tqdm(thetas, desc=\"Theta sweep\"):\n",
    "    temp = []\n",
    "    for i in range(subset):\n",
    "        ret = all_returns[i]; vol = all_vols[i]\n",
    "        mu_c = np.percentile(ret[:50], 95)\n",
