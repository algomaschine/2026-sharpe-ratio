    "# =============================================================================\n",
    "# 8. ROBUSTNESS TO TAIL INDEX ESTIMATION (OPTIONAL)\n",
    "# =============================================================================\n",
    "if RUN_ROBUSTNESS:\n",
    "    print(\"\\nRunning robustness analysis (estimated κ from each path)...\")\n",
    "    sharpe_true_eta = []\n",
    "    sharpe_est_eta = []\n",
    "    kappa_estimates = []\n",
    "    n_robust = min(200, N_PATHS)\n",
    "    for i in tqdm(range(n_robust), desc=\"Robustness\"):\n",
    "        ret = all_returns[i]; vol = all_vols[i]\n",
    "        half = len(ret)//2\n",
    "        try:\n",
    "            tail_dict = estimate_tail_index(ret[:half], tail='both')\n",
    "            k_hat = (tail_dict['left'] + tail_dict['right']) / 2\n",
    "            if k_hat <= 2: k_hat = 2.1\n",
    "        except:\n",
    "            k_hat = TRUE_KAPPA\n",
    "        kappa_estimates.append(k_hat)\n",
    "        eta_hat = 1.0 - 2.0 / k_hat\n",
    "        mu_c = np.percentile(ret[:50], 95)\n",
    "        if mu_c <= 0: mu_c = np.mean(ret[:50])\n",
    "        # True eta\n",
    "        act_t, _, _ = apply_rotation(ret, vol, mu_c, TRUE_ETA, THETA, TAU0, ALPHA_LOAD, BETA_DECAY, 'full')\n",
    "        sharpe_true_eta.append(calculate_sharpe(act_t) if len(act_t)>0 else 0.0)\n",
    "        # Estimated eta\n",
    "        act_e, _, _ = apply_rotation(ret, vol, mu_c, eta_hat, THETA, TAU0, ALPHA_LOAD, BETA_DECAY, 'full')\n",
    "        sharpe_est_eta.append(calculate_sharpe(act_e) if len(act_e)>0 else 0.0)\n",
    "    \n",
    "    print(f\"Mean estimated κ: {np.mean(kappa_estimates):.2f} (true={TRUE_KAPPA})\")\n",
    "    print(f\"Mean Sharpe (true η): {np.mean(sharpe_true_eta):.3f}\")\n",
    "    print(f\"Mean Sharpe (estimated η): {np.mean(sharpe_est_eta):.3f}\")\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(8,5))\n",
    "    bp = ax.boxplot([sharpe_true_eta, sharpe_est_eta], labels=['True η', 'Estimated η'], patch_artist=True)\n",
    "    bp['boxes'][0].set_facecolor('lightblue'); bp['boxes'][1].set_facecolor('orange')\n",
